<style>
/* ── SECTION GÉNÉRIQUE ── */
.tag { display:inline-flex;align-items:center;gap:8px;border-radius:20px;padding:5px 14px;margin-bottom:14px; }
.tag-gold { background:rgba(201,168,76,.12);border:1px solid rgba(201,168,76,.2); }
.tag-gold span { font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--gold); }

/* ── AMBITION ── */
.ambition-sec { background:var(--cream);padding:100px 60px; }
.ambition-in { max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center; }
.ambition-quote { font-family:'Playfair Display',serif;font-size:30px;font-weight:800;font-style:italic;color:var(--green);line-height:1.45;border-left:3px solid var(--gold);padding-left:28px;margin-bottom:32px; }
.ambition-sub { font-size:15px;color:var(--muted);line-height:1.8;margin-bottom:32px; }
.ambition-sig { font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--green); }
.ambition-sig em { color:var(--gold);font-style:normal; }
.ambition-pillars { display:flex;flex-direction:column;gap:14px; }
.ambition-pillar { display:flex;align-items:flex-start;gap:14px;padding:18px 20px;border-radius:14px;background:#fff;border:1px solid rgba(0,0,0,.06);box-shadow:0 2px 12px rgba(0,0,0,.04); }
.ap-icon { width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0; }
.ap-title { font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px; }
.ap-desc { font-size:12px;color:var(--muted);line-height:1.6; }

@media(max-width:900px){
  .ambition-sec { padding:60px 24px; }
  .ambition-in { grid-template-columns:1fr;gap:40px; }
}
</style>

