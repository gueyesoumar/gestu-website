    <div class="ambition-pillars">
      <div class="ambition-pillar">
        <div class="ap-icon" style="background:var(--green)">🌍</div>
        <div>
          <div class="ap-title">Locale dans son intelligence</div>
          <div class="ap-desc">Ancrée dans les réalités des institutions, États et grandes entreprises africaines. Pensée pour leurs contextes réglementaires et opérationnels.</div>
        </div>
      </div>
      <div class="ambition-pillar">
        <div class="ap-icon" style="background:var(--green)">🚀</div>
        <div>
