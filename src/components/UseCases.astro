<style>
/* ── USE CASES (carrousel horizontal) ── */
.uc-track-wrap { overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding-bottom:16px;margin:0 -60px;padding-left:60px;padding-right:60px;scrollbar-width:none; }
.uc-track-wrap::-webkit-scrollbar { display:none; }
.uc-track { display:flex;gap:24px;width:max-content; }
.uc-card { scroll-snap-align:start;width:340px;flex-shrink:0;border-radius:20px;background:#fff;border:1px solid rgba(0,0,0,.07);overflow:hidden;transition:transform .25s,box-shadow .25s;display:flex;flex-direction:column; }
.uc-card:hover { transform:translateY(-6px);box-shadow:0 20px 48px rgba(0,0,0,.1); }
.uc-card-top { height:6px;flex-shrink:0; }
.uc-card.g .uc-card-top { background:linear-gradient(90deg,var(--green),var(--green3)); }
.uc-card.b .uc-card-top { background:linear-gradient(90deg,var(--blue),#2575c4); }
.uc-card.m .uc-card-top { background:linear-gradient(90deg,#7c3aed,#a855f7); }
.uc-card.o .uc-card-top { background:linear-gradient(90deg,#d97706,#f59e0b); }
.uc-card.r .uc-card-top { background:linear-gradient(90deg,#dc2626,#ef4444); }
.uc-card.t .uc-card-top { background:linear-gradient(90deg,#0891b2,#06b6d4); }
.uc-body { padding:28px;display:flex;flex-direction:column;flex:1; }
.uc-emoji { font-size:28px;margin-bottom:12px; }
.uc-problem { font-size:13px;font-style:italic;color:var(--muted);margin-bottom:14px;padding:12px 14px;background:rgba(0,0,0,.03);border-radius:10px;border-left:3px solid #e5e7eb;line-height:1.6; }
.uc-solution { font-size:13px;color:var(--text);line-height:1.65;margin-bottom:16px;flex:1; }
.uc-sector { font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:6px; }
.uc-title { font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--text);margin-bottom:12px; }
.uc-products { display:flex;gap:8px;flex-wrap:wrap;margin-top:auto;padding-top:16px;border-top:1px solid #f3f4f6; }
.uc-product-link { font-size:10px;font-weight:700;text-decoration:none;color:var(--text);background:rgba(0,0,0,.05);padding:4px 12px;border-radius:20px;border:1px solid rgba(0,0,0,.08);transition:all .18s; }
.uc-product-link:hover { background:var(--green);color:#fff;border-color:var(--green); }
.uc-scroll-hint { display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted);margin-top:20px; }
.uc-scroll-btns { display:flex;gap:8px;margin-top:20px; }
.scroll-btn { width:40px;height:40px;border-radius:50%;border:1.5px solid #e5e7eb;background:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;color:var(--text); }
.scroll-btn:hover { background:var(--green);border-color:var(--green);color:#fff; }
@media(max-width:900px){
  .uc-track-wrap { margin:0 -24px;padding-left:24px;padding-right:24px; }
}
</style>

<!-- ══ USE CASES (CARROUSEL) ══ -->
