const liveUpdates = [
  { idx:2, dot:'#6fcf97', html:'<strong style="color:#6fcf97">A.12</strong> passé à <strong style="color:#6fcf97">Conforme</strong> · <span style="color:rgba(255,255,255,.25)">maintenant</span>' },
