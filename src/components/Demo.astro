<style>
/* ── DÉMO ── */
.demo-sec { background:linear-gradient(160deg,var(--dark) 0%,#0a3020 100%);position:relative;overflow:hidden;padding:100px 60px; }
.demo-sec::before { content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.06) 1px,transparent 1px);background-size:36px 36px; }
.demo-inner { position:relative;z-index:1; }
.demo-header { text-align:center;margin-bottom:40px; }
.demo-header h2 { color:#fff; }
.demo-header .sub { color:rgba(255,255,255,.55);margin:0 auto 0; }

/* App wrapper */
.demo-app { border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,.1);box-shadow:0 40px 100px rgba(0,0,0,.5);width:100% }
.demo-app-bar { background:rgba(0,0,0,.4);padding:10px 16px;display:flex;align-items:center;gap:8px;border-bottom:1px solid rgba(255,255,255,.06) }
.demo-app-body { display:grid;grid-template-columns:160px 1fr;min-height:580px }
.d-sidebar { background:rgba(0,0,0,.28);border-right:1px solid rgba(255,255,255,.06);padding:14px 0 }
.d-nav-section { font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.2);padding:0 14px;margin:14px 0 6px }
.d-nav { display:flex;align-items:center;gap:8px;padding:8px 14px;font-size:12px;font-weight:500;color:rgba(255,255,255,.4);cursor:pointer;transition:all .18s;border-left:2px solid transparent }
.d-nav:hover { color:rgba(255,255,255,.75);background:rgba(255,255,255,.03) }
.d-nav.active { color:#fff;background:rgba(255,255,255,.07);border-left-color:var(--gold) }
.d-nav-badge { margin-left:auto;font-size:9px;font-weight:700;background:rgba(239,68,68,.25);color:#ef4444;border-radius:10px;padding:1px 6px }
.d-main { display:flex;flex-direction:column;min-width:0 }
.d-topbar { padding:10px 18px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:space-between;flex-shrink:0 }
.d-breadcrumb { font-size:11px;color:rgba(255,255,255,.3);display:flex;align-items:center;gap:5px }
.d-breadcrumb strong { color:rgba(255,255,255,.75);font-weight:600 }
.d-topright { display:flex;align-items:center;gap:10px }
.d-live { display:flex;align-items:center;gap:5px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);border-radius:20px;padding:3px 10px;font-size:10px;font-weight:700;color:#6fcf97 }
.d-live-dot { width:6px;height:6px;border-radius:50%;background:#6fcf97;animation:pulse-dot 1.5s infinite }
.d-avatar { width:26px;height:26px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--green) }
.d-notif { position:relative;font-size:15px;cursor:pointer;color:rgba(255,255,255,.4) }
.d-notif-badge { position:absolute;top:-2px;right:-2px;width:7px;height:7px;border-radius:50%;background:#ef4444;border:1.5px solid #071F12 }
.d-mission-bar { padding:8px 18px;background:rgba(255,255,255,.02);border-bottom:1px solid rgba(255,255,255,.04);display:flex;align-items:center;gap:10px;flex-shrink:0 }
.d-mission-label { font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.22);flex-shrink:0 }
.d-mission-sel { background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:6px;padding:4px 10px;font-size:12px;color:#fff;font-family:'DM Sans',sans-serif;cursor:pointer;flex:1;max-width:340px }
.d-mission-sel option { background:#071F12 }
.d-content { flex:1;padding:14px 16px;display:grid;grid-template-columns:1fr 1fr;gap:12px;align-items:start;overflow:hidden }
.d-ctrl-list { display:flex;flex-direction:column;gap:6px }
.d-ctrl-list-title { font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.25);margin-bottom:4px }
.d-ctrl { padding:9px 11px;border-radius:8px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);cursor:pointer;transition:all .18s;display:flex;align-items:center;gap:9px }
.d-ctrl:hover,.d-ctrl.active { background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.14) }
.d-ctrl-dot { width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:1px }
.d-ctrl-info { flex:1;min-width:0 }
.d-ctrl-name { font-size:11px;font-weight:600;color:rgba(255,255,255,.8);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:3px }
.d-ctrl-meta { display:flex;align-items:center;gap:6px }
.d-av { width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:800;color:#fff;flex-shrink:0 }
.d-ctrl-date { font-size:9px;color:rgba(255,255,255,.28) }
.d-ctrl-trend { font-size:9px;font-weight:700;margin-left:auto;flex-shrink:0 }
.d-right { display:flex;flex-direction:column;gap:10px }
.d-detail { background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:13px }
.d-detail-title { font-size:11px;font-weight:700;color:rgba(255,255,255,.7);margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid rgba(255,255,255,.06) }
.d-conf-row { display:flex;gap:6px;margin-bottom:10px }
.d-conf-btn { flex:1;padding:7px 4px;border-radius:6px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.04);text-align:center;font-size:10px;font-weight:700;color:rgba(255,255,255,.4);cursor:pointer;transition:all .18s }
.d-ai-box { background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.18);border-radius:8px;padding:10px;margin-bottom:8px }
.d-ai-label { font-size:9px;font-weight:700;color:var(--gold);margin-bottom:5px;text-transform:uppercase;letter-spacing:.1em }
.d-ai-text { font-size:10px;color:rgba(255,255,255,.65);line-height:1.55 }
.d-score-row { font-size:10px;color:rgba(255,255,255,.35) }
.d-feed-box { background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:11px }
.d-feed-title { font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.22);margin-bottom:8px }
.d-feed-item { display:flex;align-items:flex-start;gap:7px;margin-bottom:7px;font-size:10px;color:rgba(255,255,255,.45);line-height:1.4 }
.d-feed-item:last-child { margin-bottom:0 }
.d-feed-av { width:18px;height:18px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:800;color:#fff }
.d-report-area { background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:11px }
.d-report-btn { width:100%;padding:9px;border-radius:7px;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--green);font-size:11px;font-weight:800;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:opacity .2s }
.d-report-btn:hover { opacity:.88 }
.d-report-prog { height:3px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden;margin-top:7px;display:none }
.d-report-bar { height:100%;background:var(--gold);border-radius:2px;width:0 }
.d-report-done { font-size:10px;color:#6fcf97;text-align:center;margin-top:6px;display:none }
/* Matrix */
.matrix-grid { display:grid;grid-template-columns:repeat(5,1fr);gap:5px;margin-bottom:16px }
.m-cell { aspect-ratio:1;border-radius:6px;cursor:pointer;transition:transform .15s,box-shadow .15s;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:rgba(255,255,255,.9) }
.m-cell:hover { transform:scale(1.12);box-shadow:0 4px 12px rgba(0,0,0,.3) }
.m-cell.cg { background:rgba(34,197,94,.35) }
.m-cell.cy { background:rgba(234,179,8,.4) }
.m-cell.co { background:rgba(249,115,22,.45) }
.m-cell.cr { background:rgba(239,68,68,.5) }
.m-cell.cd { background:rgba(139,0,0,.6) }
.risk-tooltip { font-size:12px;color:rgba(255,255,255,.6);line-height:1.6;padding:10px;background:rgba(255,255,255,.04);border-radius:8px;border:1px solid rgba(255,255,255,.06) }

@media(max-width:900px){
  .demo-app-body { grid-template-columns:1fr; }
  .d-sidebar { display:none; }
  .d-content { grid-template-columns:1fr; }
}
</style>

