  { title:"A.18 — Conformité réglementaire", ai:"Obligations légales identifiées, revue juridique en cours pour NIS2. Propriété intellectuelle couverte. Revue de conformité à documenter.", score:"Partiel", ecarts:"2", color:"#eab308", resp:"Marie L." },
];

function dShowControl(idx, el) {
  document.querySelectorAll('.d-ctrl').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  const c = dControls[idx];
  document.getElementById('dDetailTitle').textContent = c.title;
  document.getElementById('dAiText').textContent = c.ai;
  document.getElementById('dScore').innerHTML = `Score domaine : <span style="color:${c.color};font-weight:700">${c.score}</span> · ${c.ecarts} écart${Number(c.ecarts)>0?'s':''} · <span style="color:rgba(255,255,255,.3)">Responsable : ${c.resp}</span>`;
  document.querySelectorAll('#dConfRow .d-conf-btn').forEach(b => {
    b.style.background='rgba(255,255,255,.04)'; b.style.borderColor='rgba(255,255,255,.08)'; b.style.color='rgba(255,255,255,.4)';
  });
  const first = document.querySelector('#dConfRow .d-conf-btn');
  const confColors = { '#6fcf97':'rgba(34,197,94,.2)', '#f97316':'rgba(249,115,22,.18)', '#eab308':'rgba(234,179,8,.18)', '#ef4444':'rgba(239,68,68,.18)' };
  if (first) { first.style.background=confColors[c.color]||'rgba(255,255,255,.06)'; first.style.borderColor=c.color+'55'; first.style.color=c.color; }
}

function dSelectConf(el, type) {
  document.querySelectorAll('#dConfRow .d-conf-btn').forEach(b => {
    b.style.background='rgba(255,255,255,.04)'; b.style.borderColor='rgba(255,255,255,.08)'; b.style.color='rgba(255,255,255,.4)';
  });
  const bg={conforme:'rgba(34,197,94,.2)',partiel:'rgba(249,115,22,.18)',non:'rgba(239,68,68,.18)'};
  const bd={conforme:'rgba(34,197,94,.4)',partiel:'rgba(249,115,22,.3)',non:'rgba(239,68,68,.3)'};
  const tc={conforme:'#6fcf97',partiel:'#f97316',non:'#ef4444'};
  el.style.background=bg[type]; el.style.borderColor=bd[type]; el.style.color=tc[type];
}

// Navigation démo
function switchDemoTab(tab, el) {
  document.querySelectorAll('.d-nav').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
  if (tab === 'risk') {
    document.getElementById('demoAudit').style.display = 'none';
    document.getElementById('demoRisk').style.display = 'grid';
    buildMatrix();
  } else {
    document.getElementById('demoAudit').style.display = 'grid';
    document.getElementById('demoRisk').style.display = 'none';
  }
}

// Matrice risques
function buildMatrix() {
  const matrix = document.getElementById('riskMatrix');
  if (!matrix || matrix.children.length > 0) return;
  const tooltip = document.getElementById('riskTooltip');
  const data = [
    ['co',10,'Élevé','Probabilité très haute, impact modéré. Traitement prioritaire sous 30 jours.'],
    ['cr',15,'Critique','Zone rouge. Action immédiate et validation CODIR requise.'],
    ['cr',20,'Critique','Risque extrême. Suspension de l\'activité concernée envisageable.'],
    ['cd',20,'Critique','Risque catastrophique. Cellule de crise à activer sans délai.'],
    ['cd',25,'Critique','Risque maximal. Menace existentielle pour l\'organisation.'],
    ['cy',5,'Modéré','Traitement recommandé. Désigner un propriétaire de risque.'],
    ['co',10,'Élevé','Risque significatif. Plan d\'action à définir sous 30 jours.'],
    ['cr',15,'Critique','Escalade management requise. Traitement urgent.'],
    ['cr',16,'Critique','Risque critique. Validation direction et plan d\'urgence.'],
    ['cd',20,'Critique','Risque catastrophique. Action immédiate.'],
    ['cg',4,'Faible','Risque acceptable. Surveillance trimestrielle suffisante.'],
    ['cy',6,'Modéré','Risque modéré. Plan de surveillance à mettre en place.'],
    ['co',10,'Élevé','Risque élevé. Propriétaire et échéance à définir.'],
    ['cr',15,'Critique','Zone critique. Escalade et plan d\'urgence.'],
    ['cr',15,'Critique','Risque critique. Traitement prioritaire.'],
    ['cg',2,'Faible','Risque très faible. Acceptation possible.'],
    ['cg',4,'Faible','Risque faible. Revue annuelle.'],
    ['cy',6,'Modéré','Risque modéré. Revue semestrielle.'],
    ['co',10,'Élevé','Risque élevé. Traitement à planifier.'],
    ['cr',15,'Critique','Risque critique. Action rapide.'],
    ['cg',1,'Faible','Risque minimal. Aucune action requise.'],
    ['cg',2,'Faible','Risque très faible. Surveillance annuelle.'],
    ['cg',3,'Faible','Risque faible. Acceptable.'],
    ['cy',5,'Modéré','Risque modéré bas. Plan de surveillance.'],
    ['co',10,'Élevé','Impact élevé malgré faible probabilité. À surveiller.'],
  ];
  data.forEach(d => {
    const cell = document.createElement('div');
    cell.className = 'm-cell ' + d[0];
    cell.onclick = () => {
      document.querySelectorAll('.m-cell').forEach(c => c.classList.remove('selected'));
      cell.classList.add('selected');
      const col = d[0]==='cg'?'#22c55e':d[0]==='cy'?'#eab308':d[0]==='co'?'#f97316':'#ef4444';
      if (tooltip) tooltip.innerHTML = `<strong style="color:${col}">${d[2]==='Critique'?'🔴':'⚠️'} Score ${d[1]} — ${d[2]}</strong><br/>${d[3]}`;
    };
    matrix.appendChild(cell);
  });
}

// Rapport PDF simulé
document.getElementById('reportBtn')?.addEventListener('click', function() {
  const btn = this;
  btn.disabled = true; btn.textContent = 'Génération en cours…';
  const prog = document.getElementById('reportProg');
  const bar  = document.getElementById('reportBar');
  const done = document.getElementById('reportDone');
  if (prog) prog.style.display = 'block';
  setTimeout(() => { if(bar){bar.style.transition='width 2s ease'; bar.style.width='100%';} }, 50);
  setTimeout(() => {
    if(prog) prog.style.display='none';
    if(done) done.style.display='block';
    btn.textContent='📄 Générer le rapport PDF — Audit ISO 27001';
    btn.disabled=false;
    if(bar){bar.style.width='0';bar.style.transition='none';}
    setTimeout(()=>{ if(done) done.style.display='none'; }, 4000);
  }, 2200);
});

