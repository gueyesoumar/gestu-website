  { idx:4, dot:'#6fcf97', html:'<strong style="color:#6fcf97">A.18</strong> revue planifiée par Marie L. · <span style="color:rgba(255,255,255,.25)">maintenant</span>' },
];
let liveIdx = 0;
setInterval(() => {
  const u = liveUpdates[liveIdx % liveUpdates.length];
  const dot = document.querySelector('#dc'+u.idx+' .d-ctrl-dot');
  if (dot) { dot.style.background=u.dot; dot.style.boxShadow='0 0 6px '+u.dot; setTimeout(()=>dot.style.boxShadow='',2000); }
  const la = document.getElementById('liveActivity');
  if (la) la.querySelector('div:last-child').innerHTML = u.html;
  liveIdx++;
}, 8000);
