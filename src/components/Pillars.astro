<style>
/* ── PILIERS ── */
.pillars-grid { display:grid;grid-template-columns:1fr 1fr;gap:28px; }
.coming-badge { display:inline-flex;align-items:center;gap:6px;background:rgba(201,168,76,.12);border:1px solid rgba(201,168,76,.2);border-radius:20px;padding:2px 10px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--gold);margin-left:8px;vertical-align:middle; }
.pillar-card { border-radius:22px;padding:44px;position:relative;overflow:hidden;transition:transform .25s,box-shadow .25s; }
.pillar-card:hover { transform:translateY(-5px);box-shadow:0 24px 60px rgba(0,0,0,.15); }
.pillar-card.green { background:linear-gradient(145deg,var(--green),var(--green2));border:1px solid rgba(255,255,255,.08); }
.pillar-card.blue  { background:linear-gradient(145deg,#1a5fa5,#0d4a8a);border:1px solid rgba(255,255,255,.08); }
.pillar-card::after { content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.04); }
.pillar-icon { width:60px;height:60px;border-radius:16px;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;margin-bottom:24px;font-size:26px;border:1px solid rgba(255,255,255,.15); }
.pillar-tag { font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.4);margin-bottom:8px; }
.pillar-title { font-family:'Playfair Display',serif;font-size:30px;font-weight:800;color:#fff;margin-bottom:14px; }
.pillar-desc { font-size:14px;color:rgba(255,255,255,.7);line-height:1.75;margin-bottom:28px; }
.pillar-items { display:flex;flex-direction:column;gap:10px;margin-bottom:32px; }
.pillar-item { display:flex;align-items:center;gap:10px;font-size:13px;color:rgba(255,255,255,.8); }
.pillar-item::before { content:'';width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,.4);flex-shrink:0; }
.pillar-links { display:flex;gap:16px;flex-wrap:wrap; }
.pillar-link { display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:#fff;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.3);padding-bottom:2px;transition:border-color .2s; }
.pillar-link:hover { border-color:#fff; }
.pillar-mention { font-size:12px;color:rgba(255,255,255,.35);margin-top:16px;font-style:italic; }
@media(max-width:900px){
  .pillars-grid { grid-template-columns:1fr; }
}
</style>

<!-- ══ PILIERS ══ -->
