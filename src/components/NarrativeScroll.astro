<script>
// ── Narrative scroll
(function() {
  const wrap = document.getElementById('narrativeWrap');
  if (!wrap) return;
  const stages = wrap.querySelectorAll('.narrative-stage');
  let current = 0;

  function setStage(idx) {
    if (idx === current) return;
    current = idx;
    stages.forEach((s, i) => s.classList.toggle('active', i === idx));
  }

  window.addEventListener('scroll', () => {
    const rect = wrap.getBoundingClientRect();
    const scrolled = -rect.top;
    const total = wrap.offsetHeight - window.innerHeight;
    if (scrolled < 0 || scrolled > total) return;
    const pct = scrolled / total;
    const idx = Math.min(3, Math.floor(pct * 4));
    setStage(idx);
  }, { passive: true });
})();
</script>
