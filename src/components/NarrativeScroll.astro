<style>
/* ── NARRATIVE SCROLL ── */
.narrative-wrap { position:relative; }
.narrative-sticky { position:sticky;top:0;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:var(--dark); }
.narrative-stage { position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding:80px 60px;opacity:0;transition:opacity .7s ease;pointer-events:none; }
.narrative-stage.active { opacity:1;pointer-events:auto; }
.narrative-progress { position:absolute;right:36px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:14px;z-index:10; }
.np-dot { width:7px;height:7px;border-radius:50%;border:1.5px solid rgba(255,255,255,.25);transition:all .4s; }
.np-dot.active { background:var(--gold);border-color:var(--gold);transform:scale(1.4); }
.narrative-spacer { height:400vh; }
.ns-content { max-width:1100px;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center; }
.ns-badge { display:inline-flex;align-items:center;gap:8px;border-radius:20px;padding:6px 16px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.14em;margin-bottom:28px; }
.ns-number { font-family:'Playfair Display',serif;font-size:80px;font-weight:800;line-height:1;margin-bottom:12px;opacity:.15; }
.ns-title { font-family:'Playfair Display',serif;font-size:38px;font-weight:800;color:#fff;line-height:1.18;margin-bottom:16px; }
.ns-desc { font-size:15px;color:rgba(255,255,255,.6);line-height:1.8; }
.ns-visual { border-radius:20px;overflow:hidden;border:1px solid rgba(255,255,255,.08);padding:28px;min-height:320px;display:flex;flex-direction:column;gap:12px; }
/* Scroll hint */
.ns-scroll-hint { position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;animation:fadeIn 1s ease both .5s; }
.ns-scroll-hint span { font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.3); }
.ns-scroll-arrow { width:24px;height:38px;border-radius:12px;border:1.5px solid rgba(255,255,255,.15);display:flex;align-items:flex-start;justify-content:center;padding-top:6px; }
.ns-scroll-arrow::after { content:'';width:4px;height:10px;border-radius:2px;background:rgba(255,255,255,.4);animation:scrollDot 1.4s ease-in-out infinite; }
@keyframes scrollDot { 0%,100%{transform:translateY(0);opacity:1} 100%{transform:translateY(12px);opacity:0} }
@media(max-width:900px){
  .ns-content { grid-template-columns:1fr; }
}
</style>

