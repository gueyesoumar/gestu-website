.ba-clean { display:flex;flex-direction:column;gap:10px;width:100%;max-width:380px; }
.ba-metric { background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:14px 18px; }
.ba-metric-label { font-size:10px;color:rgba(255,255,255,.45);margin-bottom:4px;text-transform:uppercase;letter-spacing:.08em; }
.ba-metric-val { font-family:'Playfair Display',serif;font-size:24px;font-weight:800;color:#fff; }
.ba-metric-val em { font-size:12px;font-style:normal;color:rgba(255,255,255,.45); }
.ba-prog-row { display:flex;align-items:center;gap:10px;margin-bottom:4px; }
.ba-prog-label { font-size:11px;color:rgba(255,255,255,.7);width:90px;flex-shrink:0; }
.ba-bar-bg { flex:1;height:6px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden; }
.ba-bar-fill { height:100%;border-radius:3px;background:var(--gold); }
.ba-pct { font-size:11px;font-weight:700;color:var(--gold);width:34px;text-align:right; }
.ba-drag-hint { text-align:center;margin-top:20px;font-size:12px;color:var(--muted);display:flex;align-items:center;justify-content:center;gap:8px; }

@media(max-width:900px){
