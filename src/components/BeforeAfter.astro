.ba-email { background:#fff;border:1px solid #d1d5db;border-radius:8px;padding:9px 14px;display:flex;align-items:center;gap:10px;font-size:11px;color:#374151;box-shadow:0 1px 4px rgba(0,0,0,.06); }
