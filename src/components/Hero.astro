<style>
.hero {
  min-height:100vh;background:var(--dark);
  display:flex;align-items:center;padding:120px 60px 80px;
  position:relative;overflow:hidden;
}
.hero-grid {
  position:absolute;inset:0;
  background-image:radial-gradient(circle,rgba(255,255,255,.1) 1px,transparent 1px);
  background-size:38px 38px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent 100%);
  pointer-events:none;
}
.hero-orb-1 {
  position:absolute;top:-180px;left:-100px;width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle,rgba(10,61,36,.6) 0%,transparent 65%);pointer-events:none;
}
.hero-orb-2 {
  position:absolute;bottom:-100px;right:300px;width:400px;height:400px;border-radius:50%;
  background:radial-gradient(circle,rgba(201,168,76,.15) 0%,transparent 65%);pointer-events:none;
}
.hero-scanline {
  position:absolute;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,rgba(201,168,76,.3),transparent);
  animation:scan-line 6s ease-in-out infinite;pointer-events:none;z-index:1;
}
.hero-content { position:relative;z-index:2;max-width:620px;animation:fadeUp .8s ease both; }
.hero-eyebrow { display:flex;align-items:center;gap:10px;margin-bottom:32px; }
.hero-eyebrow-dot { width:8px;height:8px;border-radius:50%;background:var(--gold);animation:pulse-dot 2s infinite; }
.hero-eyebrow span { font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.16em;color:rgba(255,255,255,.5); }
.hero h1 { font-family:'Playfair Display',serif;font-size:62px;font-weight:800;line-height:1.08;color:#fff;margin-bottom:8px;letter-spacing:-.03em; }
.hero h1 .gold { color:var(--gold);animation:gold-glow 4s ease-in-out infinite; }
.hero-morph { font-size:18px;font-weight:500;color:rgba(255,255,255,.45);margin-bottom:24px;height:28px;overflow:hidden; }
.morph-words { display:flex;flex-direction:column;animation:morphScroll 8s cubic-bezier(.4,0,.2,1) infinite; }
.morph-words span { height:28px;line-height:28px;flex-shrink:0; }
.hero p { font-size:16px;color:rgba(255,255,255,.6);line-height:1.75;margin-bottom:40px;max-width:500px; }
.hero-btns { display:flex;gap:14px;flex-wrap:wrap; }

/* Mockup flottant */
.hero-mockup {
  position:absolute;right:60px;top:50%;transform:translateY(-50%);
  width:500px;z-index:2;animation:float 7s ease-in-out infinite;
}
.win { background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:18px;overflow:hidden;backdrop-filter:blur(12px);box-shadow:0 40px 100px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.05); }
.win-bar { background:rgba(0,0,0,.3);padding:12px 16px;display:flex;align-items:center;gap:8px; }
.dot { width:10px;height:10px;border-radius:50%; }
.win-title { font-size:11px;color:rgba(255,255,255,.3);flex:1;text-align:center;font-weight:500; }
.win-body { padding:22px; }

@media(max-width:1100px){ .hero-mockup{display:none;} }
@media(max-width:768px){ .hero{padding:100px 24px 60px;} .hero h1{font-size:40px;} }
</style>

<section class="hero" id="hero">
  <div class="hero-grid"></div>
  <div class="hero-orb-1"></div>
  <div class="hero-orb-2"></div>
  <div class="hero-scanline"></div>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <div class="hero-eyebrow-dot"></div>
      <span>Conformité · Confiance numérique · Gouvernance SI</span>
    </div>

    <h1>Le pouvoir de voir<br/>ce que les autres<br/><span class="gold">ne voient pas.</span></h1>

    <div class="hero-morph">
      <div class="morph-words">
        <span>Votre conformité est-elle réelle ou seulement apparente ?</span>
        <span>Vos risques SI sont-ils visibles avant qu'ils ne surviennent ?</span>
        <span>Vos audits produisent-ils de vraies décisions ?</span>
        <span>Vos obligations réglementaires sont-elles vraiment maîtrisées ?</span>
      </div>
    </div>

    <p>Gëstu Group transforme la conformité en avantage stratégique — par le <strong style="color:rgba(255,255,255,.9)">conseil expert</strong> et par une <strong style="color:rgba(255,255,255,.9)">plateforme de pilotage</strong> conçue pour voir, comprendre et contrôler.</p>

    <div class="hero-btns">
      <a href="#contact" class="btn-gold">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8h12M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Parler à un expert
      </a>
      <a href="#demo-sec" class="btn-ghost">Voir la démo interactive</a>
    </div>
  </div>

  <!-- Mockup flottant -->
  <div class="hero-mockup">
    <div class="win">
      <div class="win-bar">
        <div class="dot" style="background:#ff5f57"></div>
        <div class="dot" style="background:#ffbd2e"></div>
        <div class="dot" style="background:#28ca41"></div>
        <div class="win-title">Gëstu Group — Tableau de bord</div>
      </div>
      <div class="win-body">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:18px">
          <div style="width:8px;height:8px;border-radius:50%;background:var(--gold)"></div>
          <div style="font-size:11px;font-weight:700;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.1em">Vue consolidée partenaire</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px">
          <div style="background:rgba(255,255,255,.05);border-radius:10px;padding:12px;text-align:center">
            <div style="font-size:22px;font-weight:800;color:#6fcf97">12</div>
            <div style="font-size:9px;color:rgba(255,255,255,.35);margin-top:3px">Missions actives</div>
          </div>
          <div style="background:rgba(255,255,255,.05);border-radius:10px;padding:12px;text-align:center">
            <div style="font-size:22px;font-weight:800;color:var(--gold)">74%</div>
            <div style="font-size:9px;color:rgba(255,255,255,.35);margin-top:3px">Conformité moy.</div>
          </div>
          <div style="background:rgba(255,255,255,.05);border-radius:10px;padding:12px;text-align:center">
            <div style="font-size:22px;font-weight:800;color:#ef4444">3</div>
            <div style="font-size:9px;color:rgba(255,255,255,.35);margin-top:3px">Alertes critiques</div>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <span style="font-size:11px;color:rgba(255,255,255,.5)">ISO 27001</span>
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:100px;height:4px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden">
                <div style="width:82%;height:100%;background:#6fcf97;border-radius:2px"></div>
              </div>
              <span style="font-size:10px;color:#6fcf97;font-weight:700">82%</span>
            </div>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center">
            <span style="font-size:11px;color:rgba(255,255,255,.5)">NIS2</span>
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:100px;height:4px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden">
                <div style="width:61%;height:100%;background:var(--gold);border-radius:2px"></div>
              </div>
              <span style="font-size:10px;color:var(--gold);font-weight:700">61%</span>
            </div>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center">
            <span style="font-size:11px;color:rgba(255,255,255,.5)">RGPD</span>
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:100px;height:4px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden">
                <div style="width:91%;height:100%;background:#6fcf97;border-radius:2px"></div>
              </div>
              <span style="font-size:10px;color:#6fcf97;font-weight:700">91%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
