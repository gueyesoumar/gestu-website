      </div>
      <div class="footer-col">
        <div class="footer-col-title">Offres</div>
        <a href="#contact">Conseil stratégique</a>
        <a href="/gestu-control">Gëstu Control</a>
        <a href="/gestu-risk">Gëstu Risk</a>
        <a href="#offres" style="color:rgba(201,168,76,.6)">Gëstu Diligence <span style="font-size:10px;opacity:.7">— bientôt</span></a>
        <a href="#contact">Formation</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">Ressources</div>
        <a href="https://docs.gestugroup.com" class="footer-gold">docs.gestugroup.com</a>
        <a href="#usecases">Cas d'usage</a>
        <a href="#demo-sec">Démo interactive</a>
        <a href="#problemes">Solutions</a>
      </div>
      <div class="footer-col">
