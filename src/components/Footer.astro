        <a href="#">À propos</a>
        <a href="#contact">Contact</a>
        <a href="#">LinkedIn</a>
        <a href="#">Mentions légales</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-copy">© 2026 Gëstu Group · Tous droits réservés</div>
      <div class="footer-links">
        <a href="#">Confidentialité</a>
        <a href="#">CGU</a>
        <a href="https://docs.gestugroup.com" class="footer-gold">docs.gestugroup.com</a>
      </div>
    </div>
  </div>
</footer>
