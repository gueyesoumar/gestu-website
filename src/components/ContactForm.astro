<style>
/* ── FORMULAIRE ── */
.form-sec { background:linear-gradient(135deg,var(--green) 0%,#0d4a8a 100%);position:relative;overflow:hidden; }
.form-sec::before { content:'';position:absolute;top:-200px;right:-200px;width:500px;height:500px;border-radius:50%;background:rgba(255,255,255,.04); }
.form-inner { position:relative;z-index:1;max-width:680px;margin:0 auto;text-align:center; }
.form-inner h2 { color:#fff;margin-bottom:12px; }
.form-inner .sub { color:rgba(255,255,255,.65);margin:0 auto 48px; }
.form-progress { display:flex;gap:8px;justify-content:center;margin-bottom:40px; }
.fp { flex:1;max-width:80px;height:4px;border-radius:4px;background:rgba(255,255,255,.2);transition:background .3s; }
.fp.done { background:var(--gold); }
.fp.active { background:rgba(255,255,255,.7); }
.form-step { display:none;animation:fadeUp .4s ease both; }
.form-step.active { display:block; }
.form-question { font-size:20px;font-weight:700;color:#fff;margin-bottom:28px; }
.form-options { display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:32px; }
.form-option { padding:16px 20px;border-radius:12px;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.15);color:#fff;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;text-align:left;display:flex;align-items:center;gap:12px; }
.form-option:hover,.form-option.selected { background:rgba(255,255,255,.15);border-color:rgba(255,255,255,.4); }
.form-option em { font-size:20px;font-style:normal; }
.form-fields { display:flex;flex-direction:column;gap:14px;margin-bottom:28px; }
.form-field { background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.15);border-radius:10px;padding:14px 18px;color:#fff;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s; }
.form-field::placeholder { color:rgba(255,255,255,.4); }
.form-field:focus { border-color:rgba(255,255,255,.5);background:rgba(255,255,255,.1); }
.form-btn { background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--green);padding:15px 40px;border-radius:12px;font-size:15px;font-weight:800;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 24px rgba(201,168,76,.35); }
.form-btn:hover { transform:translateY(-2px);box-shadow:0 8px 32px rgba(201,168,76,.45); }
.form-back { background:none;border:none;color:rgba(255,255,255,.5);font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:12px;transition:color .2s; }
.form-back:hover { color:#fff; }
.form-success { display:none;padding:40px 0; }
.form-success.show { display:block;animation:fadeUp .5s ease both; }
@media(max-width:900px){
  .form-options { grid-template-columns:1fr; }
}
</style>

<!-- ══ FORMULAIRE 3 ÉTAPES ══ -->
<section class="form-sec" id="contact">
  <div class="si">
    <div class="form-inner">
      <div class="tag tag-gold" style="display:inline-flex;margin-bottom:14px"><span>Prenons contact</span></div>
      <h2 style="color:#fff">Quel est votre<br/>enjeu principal ?</h2>
      <p class="sub">En 3 questions, nous préparons un échange personnalisé et concret.</p>
      <div class="form-progress">
        <div class="fp active" id="fp1"></div>
        <div class="fp" id="fp2"></div>
        <div class="fp" id="fp3"></div>
      </div>
      <!-- Étape 1 -->
      <div class="form-step active" id="fs1">
        <div class="form-question">Quel est votre enjeu prioritaire ?</div>
        <div class="form-options">
          <div class="form-option" onclick="selectOption(this,'enjeu')"><em>🛡️</em> Gouvernance SI &amp; Conformité</div>
          <div class="form-option" onclick="selectOption(this,'enjeu')"><em>⚠️</em> Gestion des risques</div>
          <div class="form-option" onclick="selectOption(this,'enjeu')"><em>🔐</em> Cybersécurité</div>
          <div class="form-option" onclick="selectOption(this,'enjeu')"><em>⚡</em> Efficacité opérationnelle</div>
        </div>
        <button class="form-btn" onclick="nextStep(2)">Continuer →</button>
      </div>
      <!-- Étape 2 -->
      <div class="form-step" id="fs2">
        <div class="form-question">Vous êtes…</div>
        <div class="form-options">
          <div class="form-option" onclick="selectOption(this,'profil')"><em>🏢</em> Cabinet d'audit / Conseil</div>
          <div class="form-option" onclick="selectOption(this,'profil')"><em>💼</em> DSI / RSSI</div>
          <div class="form-option" onclick="selectOption(this,'profil')"><em>🚀</em> Dirigeant PME / ETI</div>
          <div class="form-option" onclick="selectOption(this,'profil')"><em>🏛️</em> Secteur public</div>
        </div>
        <button class="form-btn" onclick="nextStep(3)">Continuer →</button>
        <br/><button class="form-back" onclick="nextStep(1)">← Retour</button>
      </div>
      <!-- Étape 3 -->
      <div class="form-step" id="fs3">
        <div class="form-question">Vos coordonnées</div>
        <div class="form-fields">
          <input class="form-field" type="text" placeholder="Votre prénom et nom" />
          <input class="form-field" type="email" placeholder="Votre email professionnel" />
          <input class="form-field" type="text" placeholder="Votre organisation" />
          <textarea class="form-field" rows="3" placeholder="En quelques mots, votre situation actuelle (optionnel)" style="resize:vertical"></textarea>
        </div>
        <button class="form-btn" onclick="submitForm()">Envoyer ma demande →</button>
        <br/><button class="form-back" onclick="nextStep(2)">← Retour</button>
      </div>
      <!-- Succès -->
      <div class="form-success" id="formSuccess">
        <div style="width:80px;height:80px;border-radius:50%;background:rgba(201,168,76,.2);border:2px solid var(--gold);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;font-size:32px">✓</div>
        <div style="font-size:24px;font-weight:800;color:#fff;margin-bottom:12px;font-family:'Playfair Display',serif">Demande envoyée !</div>
        <div style="font-size:15px;color:rgba(255,255,255,.65);line-height:1.7;margin-bottom:28px">Nous reviendrons vers vous sous <strong style="color:#fff">24 heures</strong> avec une proposition d'échange adaptée à votre enjeu.</div>
        <div style="font-size:13px;color:rgba(255,255,255,.35)">En attendant, explorez nos pages produits ↓</div>
      </div>
    </div>
  </div>
</section>

<script>
// ── Formulaire 3 étapes
function selectOption(el, group) {
  el.closest('.form-options').querySelectorAll('.form-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}
function nextStep(n) {
  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.fp').forEach((f,i) => { f.classList.remove('active','done'); if(i<n-1) f.classList.add('done'); if(i===n-1) f.classList.add('active'); });
  const step = document.getElementById('fs'+n);
  if(step) step.classList.add('active');
}
function submitForm() {
  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.fp').forEach(f => f.classList.add('done'));
  document.getElementById('formSuccess').classList.add('show');
}
</script>
